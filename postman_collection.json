        {
          "name": "Get Low-Stock Items",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Response is an array', () => pm.expect(body).to.be.an('array'));",
                  "if (body.length > 0) {",
                  "    pm.test('Every item has required fields', () => {",
                  "        body.forEach(item => {",
                  "            pm.expect(item).to.have.all.keys('sku','medicine_name','quantity','requires_prescription');",
                  "        });",
                  "    });",
                  "    pm.test('Every item quantity < 50', () => {",
                  "        body.forEach(item => pm.expect(item.quantity).to.be.below(50));",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/inventory/low-stock",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "inventory",
                "low-stock"
              ]
            },
            "description": "Returns all SKUs whose quantity is below 50. Seeded data includes MED-089 (12), MED-102 (5), MED-201 (8)."
          },
          "response": [
            {
              "name": "200 – Low-stock list",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/api/inventory/low-stock"
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "[\n  {\"sku\":\"MED-089\",\"medicine_name\":\"Ibuprofen 200mg\",\"quantity\":12,\"requires_prescription\":false},\n  {\"sku\":\"MED-102\",\"medicine_name\":\"Lisinopril 10mg\",\"quantity\":5,\"requires_prescription\":true},\n  {\"sku\":\"MED-201\",\"medicine_name\":\"Cetirizine 10mg\",\"quantity\":8,\"requires_prescription\":false}\n]"
            }
          ]
        }
