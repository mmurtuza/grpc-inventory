    {
      "name": "REST API – Write",
      "description": "POST / PUT / DELETE endpoints. Run in top-to-bottom order; the POST saves the new SKU into the `created_sku` variable used by PUT and DELETE.",
      "item": [
        {
          "name": "Add Stock – POST (valid)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a unique SKU so the test is idempotent across runs",
                  "const ts = Date.now();",
                  "pm.collectionVariables.set('created_sku', 'TEST-' + ts);",
                  "pm.collectionVariables.set('new_sku_payload', JSON.stringify({",
                  "    sku: 'TEST-' + ts,",
                  "    medicine_name: 'Test Drug 100mg',",
                  "    quantity: 75,",
                  "    requires_prescription: false",
                  "}));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('SKU echoed back', () => pm.expect(body.sku).to.eql(pm.collectionVariables.get('created_sku')));",
                  "pm.test('quantity is 75', () => pm.expect(body.quantity).to.eql(75));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{new_sku_payload}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/inventory",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "inventory"
              ]
            },
            "description": "Creates a new inventory item. A pre-request script generates a unique timestamped SKU and stores it in `{{created_sku}}` for the subsequent PUT and DELETE requests."
          },
          "response": [
            {
              "name": "201 – Created",
              "originalRequest": {
                "method": "POST",
                "url": {
                  "raw": "{{base_url}}/api/inventory"
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\"sku\":\"MED-999\",\"medicine_name\":\"Test Drug 100mg\",\"quantity\":75,\"requires_prescription\":false}"
                }
              },
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"sku\": \"MED-999\",\n  \"medicine_name\": \"Test Drug 100mg\",\n  \"quantity\": 75,\n  \"requires_prescription\": false\n}"
            }
          ]
        },
