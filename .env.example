# ─────────────────────────────────────────────────────────────────────────────
# gRPC Inventory — Environment Variables
#
# Copy this file to .env and fill in the values.
# The .env file is gitignored and should never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Full DSN for the inventory Postgres database.
# Format: postgres://<user>:<password>@<host>:<port>/<dbname>?sslmode=<mode>
DATABASE_URL=postgres://inventory:secret@localhost:5432/inventory?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────

# Full URL for the Redis cache instance.
# The REST API falls back to a no-op cache if Redis is unreachable.
REDIS_URL=redis://localhost:6379

# ── REST API ──────────────────────────────────────────────────────────────────

# Port the REST inventory API listens on.
REST_API_PORT=8080

# Log output format: "json" (production) or "text" (local dev, default).
LOG_FORMAT=text

# CORS allowed origin. Use a specific domain in production.
ALLOWED_ORIGIN=*

# ── gRPC Server ───────────────────────────────────────────────────────────────

# Port the gRPC server listens on.
GRPC_PORT=50051

# Base URL of the downstream REST API that the gRPC server proxies to.
REST_API_URL=http://localhost:8080

# ── gRPC Client ───────────────────────────────────────────────────────────────

# Address of the gRPC server the client connects to.
SERVER_ADDR=localhost:50051
